{
  "name": "hotel-backend",
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "build": "bun build src/index.ts --target=bun --outdir=dist",
    "start": "bun dist/index.js",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "bun run tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest --run",
    "test:watch": "vitest",
    "test:coverage": "vitest --run --coverage",
    "test:ui": "vitest --ui",
    "prisma:init": "bunx --bun prisma init",
    "prisma:generate": "bunx --bun prisma generate",
    "prisma:migrate": "bunx --bun prisma migrate dev",
    "prisma:reset": "bunx --bun prisma migrate reset",
    "prisma:pull": "bunx --bun prisma db pull",
    "prisma:studio": "bunx --bun prisma studio",
    "auth:generate": "bun x auth@latest generate --config src/common/libraries/auth.ts"
  },
  "dependencies": {
    "@better-auth/prisma-adapter": "^1.5.5",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "better-auth": "^1.5.5",
    "hono": "^4.12.8",
    "pg": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "@types/pg": "^8.18.0",
    "prisma": "^7.5.0",
    "vitest": "^4.1.0"
  }
}
