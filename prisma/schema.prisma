// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

//======================================================================================
//====================================BETTER-AUTH=======================================
//======================================================================================

model User {
  id            String    @id
  name          String
  email         String
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  role          String?
  banned        Boolean?  @default(false)
  banReason     String?
  banExpires    DateTime?
  sessions        Session[]
  accounts        Account[]

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  impersonatedBy String?

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

//======================================================================================
//========================================HOTEL=========================================
//======================================================================================

// ============================================================
// INVENTARIO ENUMS
// ============================================================

enum UnidadInsumo {
  UNIDAD
  LITRO
  KG
  GR
  BOTELLA
  CAJA
  FCO
  SACO
  TUBO
  BLISTER
  PAQUETE

  @@map("unidad_insumo")
}

enum TipoMovimiento {
  ENTRADA
  SALIDA

  @@map("tipo_movimiento")
}

enum MotivoEntrada {
  COMPRA
  DONACION
  AJUSTE
  REPOSICION

  @@map("motivo_entrada")
}

enum MotivoSalida {
  CONSUMO
  DESECHO
  AJUSTE
  STOCK_MINIMO

  @@map("motivo_salida")
}

enum AreaInventario {
  BAR
  COCINA

  @@map("area_inventario")
}

// ============================================================
// ENUMS
// Valores en español para coincidir con el SQL de la BD.
// createdAt / updatedAt siempre en inglés (convención Prisma).
// ============================================================

enum TipoCanal {
  OTA
  DIRECTO
  AGENTE

  @@map("tipo_canal")
}

enum TipoDocIdentidad {
  DNI
  PASAPORTE
  RUC
  CE

  @@map("tipo_doc_identidad")
}

enum Genero {
  M
  F
  O

  @@map("genero")
}

enum EstadoLimpieza {
  LIMPIA
  SUCIA
  EN_LIMPIEZA
  INSPECCION

  @@map("estado_limpieza")
}

enum CondicionMueble {
  BUENO
  REGULAR
  DANADO
  FALTANTE

  @@map("condicion_mueble")
}

enum PoliticaCancelacion {
  FLEXIBLE
  MODERADA
  ESTRICTA
  NO_REEMBOLSABLE

  @@map("politica_cancelacion")
}

enum TipoTemporada {
  BAJA
  MEDIA
  ALTA
  MUY_ALTA

  @@map("tipo_temporada")
}

enum EstadoReserva {
  TENTATIVA
  CONFIRMADA
  EN_CASA
  COMPLETADA
  CANCELADA
  NO_LLEGO

  @@map("estado_reserva")
}

enum ConceptoPago {
  RESERVA
  CONSUMO

  @@map("concepto_pago")
}

enum EstadoPago {
  CONFIRMADO
  DEVUELTO
  RETENIDO
  ANULADO

  @@map("estado_pago")
}

enum MetodoPago {
  EFECTIVO
  VISA
  MASTERCARD
  AMEX
  TRANSFERENCIA

  @@map("metodo_pago")
}

enum TipoDescuento {
  PORCENTAJE
  MONTO_FIJO

  @@map("tipo_descuento")
}


// ============================================================
// MODELOS
// ============================================================

// ------------------------------------------------------------
// 1. CANALES DE VENTA
// ------------------------------------------------------------

model Canal {
  id        String    @id @default(uuid()) @db.Uuid
  nombre    String    @unique @db.VarChar
  tipo      TipoCanal
  activo    Boolean   @default(true)
  notas     String?   @db.Text
  createdAt DateTime  @default(now()) @db.Timestamptz
  updatedAt DateTime  @updatedAt @db.Timestamptz

  tarifas Tarifa[]

  @@map("canales")
}

// ------------------------------------------------------------
// 3. HUÉSPEDES
// ------------------------------------------------------------

model Huesped {
  id           String            @id @default(uuid()) @db.Uuid
  tipoDoc      TipoDocIdentidad?
  nroDoc       String?           @db.VarChar(20)
  nombres      String            @db.VarChar(80)
  apellidos    String            @db.VarChar(80)
  email        String            @unique @db.VarChar(120)
  telefono     String            @db.VarChar(20)
  nacionalidad String            @db.VarChar(60)
  observacion  String?           @db.Text
  createdAt    DateTime          @default(now()) @db.Timestamptz
  updatedAt    DateTime          @updatedAt @db.Timestamptz

  reservas  Reserva[]

  @@map("huespedes")
}

// ------------------------------------------------------------
// 4. MUEBLES
// ------------------------------------------------------------

model Mueble {
  id             String          @id @default(uuid()) @db.Uuid
  codigo         String          @unique @db.VarChar(30)
  nombre         String          @db.VarChar(100)
  categoriaId    String          @db.Uuid
  urlImagen      String?         @db.Text
  condicion      CondicionMueble @default(BUENO)
  fechaAdq       DateTime?       @db.Date
  ultimaRevision DateTime?       @db.Date
  descripcion    String?         @db.Text
  habitacionId   String?         @db.Uuid
  createdAt      DateTime        @default(now()) @db.Timestamptz
  updatedAt      DateTime        @updatedAt @db.Timestamptz

  categoria  CategoriaMueble @relation(fields: [categoriaId], references: [id])
  habitacion Habitacion?     @relation(fields: [habitacionId], references: [id])

  @@map("muebles")
}

// ------------------------------------------------------------
// 5. TIPOS DE HABITACIÓN
// ------------------------------------------------------------

model TipoHabitacion {
  id        String   @id @default(uuid()) @db.Uuid
  nombre    String   @db.VarChar(100) @unique
  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  habitaciones Habitacion[]
  tarifas      Tarifa[]

  @@map("tipos_habitacion")
}

// ------------------------------------------------------------
// 6. HABITACIONES
// ------------------------------------------------------------

model Habitacion {
  id               String           @id @default(uuid()) @db.Uuid
  nroHabitacion    String           @unique @db.VarChar(10)
  tipoHabitacionId String           @db.Uuid
  piso             Int
  feature          String?          @db.Text
  amenities        String?          @db.Text
  urlImagen        String[]         @db.VarChar(255)
  estado           Boolean          @default(false)
  descripcion      String?          @db.Text
  createdAt        DateTime         @default(now()) @db.Timestamptz
  updatedAt        DateTime         @updatedAt @db.Timestamptz

  muebles     Mueble[]
  tipo        TipoHabitacion @relation(fields: [tipoHabitacionId], references: [id])
  reservas    Reserva[]
  promociones Promocion[]

  @@map("habitaciones")
}

// ------------------------------------------------------------
// 7. TARIFAS
// ------------------------------------------------------------

model Tarifa {
  id               String   @id @default(uuid()) @db.Uuid
  tipoHabitacionId String   @db.Uuid
  canalId          String   @db.Uuid
  precio           Decimal  @db.Decimal(10, 2)
  unidad           String   @default("noches") @db.VarChar(6)
  IVA              Decimal? @db.Decimal(4, 2)
  cargoServicios   Decimal? @db.Decimal(4, 2)
  moneda           String   @default("USD") @db.Char(3)
  createdAt        DateTime @default(now()) @db.Timestamptz
  updatedAt        DateTime @updatedAt @db.Timestamptz

  tipoHabitacion TipoHabitacion @relation(fields: [tipoHabitacionId], references: [id])
  canal          Canal          @relation(fields: [canalId], references: [id])
  reservas       Reserva[]

  @@map("tarifas")
}

// ------------------------------------------------------------
// 7. TARIFAS
// ------------------------------------------------------------

model Reserva {
  id           String  @id @default(uuid()) @db.Uuid
  codigo       String  @unique @db.VarChar(20)
  // Relaciones
  huespedId    String  @db.Uuid
  habitacionId String  @db.Uuid
  tarifaId     String  @db.Uuid
  pagoId       String? @unique @db.Uuid

  // Fechas
  fechaInicio DateTime @db.Timestamptz
  fechaFin    DateTime @db.Timestamptz

  // Ocupación
  adultos Int @default(1) @db.SmallInt
  ninos   Int @default(0) @db.SmallInt

  // Snapshot (desnormalización)
  nombreHuesped String @db.VarChar(100)
  nroHabitacion String @db.VarChar(10)
  nombreTipoHab String @db.VarChar(100)
  nombreCanal   String @db.VarChar(50)

  // Precios
  precioTarifa    Decimal @db.Decimal(10, 2)
  unidadTarifa    String  @db.VarChar(6)
  cantidadUnidad  Int     @db.SmallInt
  IVA            Decimal @default(0) @db.Decimal(4, 2)
  cargoServicios Decimal @default(0) @db.Decimal(4, 2)

  // Totales
  montoTotal   Decimal  @db.Decimal(10, 2)
  montoDescuento Decimal @default(0) @db.Decimal(10, 2)
  promociones String[] @db.VarChar(50)

  // Estado
  estado       EstadoReserva @default(TENTATIVA)
  motivoCancel String?       @db.Text
  canceladoEn  DateTime?     @db.Timestamptz
  // Auditoría
  createdAt    DateTime      @default(now()) @db.Timestamptz
  updatedAt    DateTime      @updatedAt @db.Timestamptz

  // Relaciones
  huesped    Huesped    @relation(fields: [huespedId], references: [id])
  habitacion Habitacion @relation(fields: [habitacionId], references: [id])
  tarifa     Tarifa     @relation(fields: [tarifaId], references: [id])
  pago       Pago?      @relation("PagoReserva", fields: [pagoId], references: [id])
  folios     Folio[]

  @@index([huespedId])
  @@index([habitacionId])
  @@index([tarifaId])
  @@index([fechaInicio])
  @@index([fechaFin])
  @@index([estado])
  @@map("reservas")
}

// ------------------------------------------------------------
// 15. PAGOS
// ------------------------------------------------------------

model Pago {
  id            String       @id @default(uuid()) @db.Uuid
  concepto      ConceptoPago
  estado        EstadoPago   @default(CONFIRMADO)
  fechaPago     DateTime     @default(now()) @db.Timestamptz
  monto         Decimal      @db.Decimal(12, 2)
  moneda        String       @default("SOL") @db.Char(3)
  metodo        MetodoPago
  recibidoPorId String? // No es UUID, es el ID de User de Better Auth
  observacion   String?      @db.Text
  createdAt     DateTime     @default(now()) @db.Timestamptz
  updatedAt     DateTime     @updatedAt @db.Timestamptz

  reserva     Reserva? @relation("PagoReserva")
  folio       Folio?   @relation("PagoFolio")

  @@map("pagos")
}

// ------------------------------------------------------------
// 16. FOLIOS
// ------------------------------------------------------------

model Folio {
  id           String          @id @default(uuid()) @db.Uuid
  codigo       String          @unique @db.VarChar(20)
  reservaId   String           @db.Uuid
  pagoId       String?         @unique @db.Uuid
  estado       Boolean         @default(true)
  observacion String?          @db.Text
  cerradoEn    DateTime?       @db.Timestamptz
  createdAt    DateTime        @default(now()) @db.Timestamptz
  updatedAt    DateTime        @updatedAt @db.Timestamptz

  reserva        Reserva        @relation(fields: [reservaId], references: [id])
  pago           Pago?          @relation("PagoFolio", fields: [pagoId], references: [id])
  folioProductos FolioProducto[]
  folioServicios FolioServicio[]
  promociones    Promocion[]

  @@index([reservaId])
  @@index([estado])
  @@map("folios")
}

// ------------------------------------------------------------
// 18. FOLIO PRODUCTOS
// ------------------------------------------------------------

model FolioProducto {
  id         String   @id @default(uuid()) @db.Uuid
  folioId    String    @db.Uuid
  productoId String    @db.Uuid
  cantidad   Int       @default(1) @db.Integer
  precioUnit Decimal   @db.Decimal(6, 2)
  total      Decimal   @db.Decimal(10, 2)
  createdAt  DateTime  @default(now()) @db.Timestamptz
  updatedAt  DateTime  @updatedAt @db.Timestamptz

  folio    Folio    @relation(fields: [folioId], references: [id], onDelete: Cascade)
  producto Producto @relation(fields: [productoId], references: [id])

  @@index([folioId])
  @@index([productoId])
  @@map("folio_productos")
}

// ------------------------------------------------------------
// 19. FOLIO SERVICIOS
// ------------------------------------------------------------

model FolioServicio {
  id         String   @id @default(uuid()) @db.Uuid
  folioId    String   @db.Uuid
  concepto   String   @db.VarChar(150)
  cantidad   Int      @default(1) @db.Integer
  precioUnit Decimal  @db.Decimal(6, 2)
  total      Decimal  @db.Decimal(10, 2)
  createdAt  DateTime @default(now()) @db.Timestamptz
  updatedAt  DateTime @updatedAt @db.Timestamptz

  folio Folio @relation(fields: [folioId], references: [id], onDelete: Cascade)

  @@index([folioId])
  @@map("folio_servicios")
}

// ------------------------------------------------------------
// 18. CATEGORIA MUEBLE
// ------------------------------------------------------------

model CategoriaMueble {
  id        String   @id @default(uuid()) @db.Uuid
  nombre    String   @unique @db.VarChar(50)
  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  muebles Mueble[]

  @@map("categoria_mueble")
}

// ------------------------------------------------------------
// 19. PROMOCIONES
// ------------------------------------------------------------

model Promocion {
  id               String         @id @default(uuid()) @db.Uuid
  codigo           String         @unique @db.VarChar(50)
  tipoDescuento    TipoDescuento
  valorDescuento   Decimal        @db.Decimal(6, 2)
  vigDesde         DateTime       @db.Timestamptz
  vigHasta         DateTime       @db.Timestamptz
  estado           Boolean        @default(true)
  createdAt        DateTime       @default(now()) @db.Timestamptz
  updatedAt        DateTime       @updatedAt @db.Timestamptz

  habitaciones Habitacion[]
  folios       Folio[]

  @@map("promociones")
}

// ------------------------------------------------------------
// 21. PRODUCTOS
// ------------------------------------------------------------

model Producto {
  id            String          @id @default(uuid()) @db.Uuid
  codigo        String          @unique @db.VarChar(30)
  nombre        String          @db.VarChar(150)
  descripcion   String?         @db.Text
  precioUnitario Decimal       @db.Decimal(6, 2)
  stock         Int             @default(0) @db.Integer
  createdAt     DateTime        @default(now()) @db.Timestamptz
  updatedAt     DateTime        @updatedAt @db.Timestamptz

  folioProductos FolioProducto[]

  @@map("productos")
}

// ============================================================
// INVENTARIO BAR
// ============================================================

model InsumoBar {
  id            String      @id @default(uuid()) @db.Uuid
  codigo        String     @unique @db.VarChar(30)
  nombre        String     @db.VarChar(150)
  unidad       UnidadInsumo
  stockActual  Decimal    @default(0) @db.Decimal(10, 3)
  stockMinimo  Decimal    @default(0) @db.Decimal(10, 3)
  activo      Boolean    @default(true)
  notas        String?    @db.Text
  createdAt    DateTime   @default(now()) @db.Timestamptz
  updatedAt    DateTime   @updatedAt @db.Timestamptz

  movimientos MovimientoBar[]

  @@map("insumos_bar")
}

model MovimientoBar {
  id          String          @id @default(uuid()) @db.Uuid
  insumoId    String          @db.Uuid
  tipo        TipoMovimiento
  cantidad   Decimal        @db.Decimal(10, 3)
  motivoEntrada MotivoEntrada?
  motivoSalida  MotivoSalida?
  notas       String?        @db.Text
  createdAt   DateTime       @default(now()) @db.Timestamptz

  insumo     InsumoBar @relation(fields: [insumoId], references: [id], onDelete: Cascade)

  @@index([insumoId])
  @@index([createdAt])
  @@map("movimientos_bar")
}

// ============================================================
// INVENTARIO COCINA
// ============================================================

model InsumoCocina {
  id            String      @id @default(uuid()) @db.Uuid
  codigo        String     @unique @db.VarChar(30)
  nombre        String     @db.VarChar(150)
  unidad       UnidadInsumo
  stockActual  Decimal    @default(0) @db.Decimal(10, 3)
  stockMinimo  Decimal    @default(0) @db.Decimal(10, 3)
  activo      Boolean    @default(true)
  notas        String?    @db.Text
  createdAt    DateTime   @default(now()) @db.Timestamptz
  updatedAt    DateTime   @updatedAt @db.Timestamptz

  movimientos MovimientoCocina[]

  @@map("insumos_cocina")
}

model MovimientoCocina {
  id          String          @id @default(uuid()) @db.Uuid
  insumoId    String          @db.Uuid
  tipo        TipoMovimiento
  cantidad   Decimal        @db.Decimal(10, 3)
  motivoEntrada MotivoEntrada?
  motivoSalida  MotivoSalida?
  notas       String?        @db.Text
  createdAt   DateTime       @default(now()) @db.Timestamptz

  insumo     InsumoCocina @relation(fields: [insumoId], references: [id], onDelete: Cascade)

  @@index([insumoId])
  @@index([createdAt])
  @@map("movimientos_cocina")
}