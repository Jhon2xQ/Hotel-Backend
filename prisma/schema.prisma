// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}


//======================================================================================
//====================================BETTER-AUTH=======================================
//======================================================================================

model User {
  id            String    @id
  name          String
  email         String
  emailVerified Boolean   @default(false)
  image         String?
  role          String    @default("PERSONAL")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions      Session[]
  accounts      Account[]
  staff         Personal?

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

//======================================================================================
//========================================HOTEL=========================================
//======================================================================================

// ============================================================
// ENUMS
// Valores en español para coincidir con el SQL de la BD.
// createdAt / updatedAt siempre en inglés (convención Prisma).
// ============================================================

enum TipoCanal {
  OTA
  DIRECTO
  AGENCIA
  CORPORATIVO
  OPERADOR

  @@map("tipo_canal")
}

enum TipoDocumento {
  DNI
  PASAPORTE
  CE
  RUC

  @@map("tipo_documento")
}

enum Genero {
  M
  F
  O

  @@map("genero")
}

enum EstadoHabitacion {
  DISPONIBLE
  RESERVADA
  OCUPADA
  LIMPIEZA
  MANTENIMIENTO

  @@map("estado_habitacion")
}

enum EstadoLimpieza {
  LIMPIA
  SUCIA
  EN_LIMPIEZA
  INSPECCION

  @@map("estado_limpieza")
}

enum CondicionMueble {
  BUENO
  REGULAR
  DANADO
  FALTANTE

  @@map("condicion_mueble")
}

enum CategoriaMueble {
  CAMA
  ASIENTO
  ALMACENAJE
  TECNOLOGIA
  BANO
  DECORACION
  OTRO

  @@map("categoria_mueble")
}

enum PoliticaCancelacion {
  FLEXIBLE
  MODERADA
  ESTRICTA
  NO_REEMBOLSABLE

  @@map("politica_cancelacion")
}

enum TipoTemporada {
  BAJA
  MEDIA
  ALTA
  MUY_ALTA

  @@map("tipo_temporada")
}

enum EstadoReserva {
  TENTATIVA
  CONFIRMADA
  EN_CASA
  COMPLETADA
  CANCELADA
  NO_LLEGO

  @@map("estado_reserva")
}

enum ConceptoPago {
  DEPOSITO
  SALDO
  ABONO
  DEVOLUCION
  RETENIDO

  @@map("concepto_pago")
}

enum EstadoPago {
  CONFIRMADO
  APLICADO
  DEVUELTO
  RETENIDO
  ANULADO

  @@map("estado_pago")
}

enum MetodoPago {
  EFECTIVO
  VISA
  MASTERCARD
  AMEX
  TRANSFERENCIA
  CREDITO_AGENCIA
  VOUCHER

  @@map("metodo_pago")
}

enum EstadoEstadia {
  EN_CASA
  COMPLETADA
  SALIDA_ANTICIPADA

  @@map("estado_estadia")
}

enum EstadoFolio {
  ABIERTO
  CERRADO
  TRANSFERIDO

  @@map("estado_folio")
}

enum CategoriaServicio {
  HABITACION
  ALIMENTO
  BEBIDA
  SPA
  TOUR
  LAVANDERIA
  TRANSPORTE
  MINIBAR
  OTRO

  @@map("categoria_servicio")
}

enum TipoComprobante {
  BOLETA
  FACTURA
  NOTA_CREDITO

  @@map("tipo_comprobante")
}

enum EstadoSunat {
  PENDIENTE
  ACEPTADO
  RECHAZADO
  ANULADO

  @@map("estado_sunat")
}

enum RolPersonal {
  RECEPCIONISTA
  GERENTE
  CAMARERA
  BELLBOY
  MOZO
  CONTADOR
  SEGURIDAD
  OTRO

  @@map("rol_personal")
}

// ============================================================
// MODELOS
// ============================================================

// ------------------------------------------------------------
// 1. CANALES DE VENTA
// ------------------------------------------------------------

model Canal {
  id           String    @id @default(uuid()) @db.Uuid
  codigo       String    @unique @db.VarChar(20)
  nombre       String    @db.VarChar(100)
  tipo         TipoCanal
  comisionPct  Decimal   @default(0) @db.Decimal(5, 2)
  activo       Boolean   @default(true)
  notas        String?   @db.Text
  createdAt    DateTime  @default(now())  @db.Timestamptz
  updatedAt    DateTime  @updatedAt @db.Timestamptz

  agencias    Agencia[]
  tarifas     Tarifa[]
  reservas    Reserva[]

  @@map("canales")
}

// ------------------------------------------------------------
// 2. AGENCIAS Y EMPRESAS
// ------------------------------------------------------------

model Agencia {
  id             String   @id @default(uuid()) @db.Uuid
  canalId        String   @db.Uuid
  ruc            String?  @db.VarChar(11)
  nombre         String   @db.VarChar(150)
  contacto       String?  @db.VarChar(100)
  email          String?  @db.VarChar(100)
  telefono       String?  @db.VarChar(20)
  direccion      String?  @db.Text
  ciudad         String?  @db.VarChar(80)
  pais           String   @default("Peru") @db.VarChar(60)
  limiteCredito  Decimal  @default(0) @db.Decimal(10, 2)
  diasPago       Int      @default(30)
  activo         Boolean  @default(true)
  createdAt      DateTime @default(now()) @db.Timestamptz
  updatedAt      DateTime @updatedAt @db.Timestamptz

  canal    Canal     @relation(fields: [canalId], references: [id])
  reservas Reserva[]

  @@map("agencias")
}

// ------------------------------------------------------------
// 3. HUÉSPEDES
// ------------------------------------------------------------

model Huesped {
  id           String         @id @default(uuid()) @db.Uuid
  nombres      String         @db.VarChar(80)
  apellidos    String         @db.VarChar(80)
  email        String?        @unique @db.VarChar(120)
  telefono     String?        @db.VarChar(20)
  nacionalidad String?        @db.VarChar(60)
  tipoDoc      TipoDocumento?
  nroDoc       String?        @db.VarChar(30)
  fechaNac     DateTime?      @db.Date
  genero       Genero?
  idioma       String         @default("es") @db.VarChar(10)
  nivelVip     Int            @default(0)
  notas        String?        @db.Text
  createdAt    DateTime       @default(now()) @db.Timestamptz
  updatedAt    DateTime       @updatedAt @db.Timestamptz

  resumen  ResumenEstancias?
  reservas Reserva[]
  estancias Estancia[]

  @@unique([tipoDoc, nroDoc])
  @@map("huespedes")
}

// Estadísticas de fidelización — se actualiza desde la app al cerrar folio
model ResumenEstancias {
  huespedId       String    @id @db.Uuid
  totalEstancias  Int       @default(0)
  totalNoches     Int       @default(0)
  totalGastado    Decimal   @default(0) @db.Decimal(12, 2)
  ultimaEstancia  DateTime? @db.Date
  primeraEstancia DateTime? @db.Date

  huesped Huesped @relation(fields: [huespedId], references: [id])

  @@map("resumen_estancias")
}

// ------------------------------------------------------------
// 4. TIPOS DE HABITACIÓN
// ------------------------------------------------------------

model TipoHabitacion {
  id            String   @id @default(uuid()) @db.Uuid
  codigo        String   @unique @db.VarChar(20)
  nombre        String   @db.VarChar(100)
  descripcion   String?  @db.Text
  areaM2        Decimal? @db.Decimal(6, 1)
  tipoCama      String?  @db.VarChar(50)
  vista         String?  @db.VarChar(50)
  pisos         String?  @db.VarChar(20)
  tieneTina     Boolean  @default(false)
  tieneJacuzzi  Boolean  @default(false)
  tieneSala     Boolean  @default(false)
  tieneCocina   Boolean  @default(false)
  urlImagen     String?  @db.VarChar(255)
  createdAt     DateTime @default(now()) @db.Timestamptz
  updatedAt     DateTime @updatedAt @db.Timestamptz

  habitaciones    Habitacion[]
  tarifas         Tarifa[]
  mueblesTipo     MueblesPorTipo[]
  reservas        Reserva[]

  @@map("tipos_habitacion")
}

// ------------------------------------------------------------
// 5. CATÁLOGO DE MUEBLES
// ------------------------------------------------------------

model CatalogoMueble {
  id          String          @id @default(uuid()) @db.Uuid
  codigo      String          @unique @db.VarChar(30)
  nombre      String          @db.VarChar(100)
  categoria   CategoriaMueble
  descripcion String?         @db.Text
  createdAt   DateTime        @default(now()) @db.Timestamptz
  updatedAt   DateTime        @updatedAt @db.Timestamptz

  mueblesTipo      MueblesPorTipo[]
  mueblesHabitacion MuebleHabitacion[]

  @@map("catalogo_muebles")
}

// ------------------------------------------------------------
// 6. INVENTARIO ESTÁNDAR POR TIPO (plantilla)
// ------------------------------------------------------------

model MueblesPorTipo {
  id               String   @id @default(uuid()) @db.Uuid
  tipoHabitacionId String   @db.Uuid
  muebleId         String   @db.Uuid
  cantidad         Int      @default(1)
  obligatorio      Boolean  @default(true)
  notas            String?  @db.Text
  createdAt        DateTime @default(now()) @db.Timestamptz
  updatedAt        DateTime @updatedAt @db.Timestamptz

  tipoHabitacion TipoHabitacion @relation(fields: [tipoHabitacionId], references: [id])
  mueble         CatalogoMueble @relation(fields: [muebleId], references: [id])

  @@unique([tipoHabitacionId, muebleId])
  @@map("muebles_por_tipo")
}

// ------------------------------------------------------------
// 7. HABITACIONES
// ------------------------------------------------------------

model Habitacion {
  id             String           @id @default(uuid()) @db.Uuid
  nroHabitacion  String           @unique @db.VarChar(10)
  tipoId         String           @db.Uuid
  piso           Int
  estado         EstadoHabitacion @default(DISPONIBLE)
  limpieza       EstadoLimpieza   @default(LIMPIA)
  accesible      Boolean          @default(false)
  notas          String?          @db.Text
  ultimaLimpieza DateTime?        @db.Timestamptz
  createdAt      DateTime         @default(now()) @db.Timestamptz
  updatedAt      DateTime         @updatedAt @db.Timestamptz

  tipo      TipoHabitacion     @relation(fields: [tipoId], references: [id])
  muebles   MuebleHabitacion[]
  estancias Estancia[]

  @@map("habitaciones")
}

// ------------------------------------------------------------
// 8. INVENTARIO REAL POR HABITACIÓN
// ------------------------------------------------------------

model MuebleHabitacion {
  id             String          @id @default(uuid()) @db.Uuid
  habitacionId   String          @db.Uuid
  muebleId       String          @db.Uuid
  nroSerie       String?         @db.VarChar(60)
  condicion      CondicionMueble @default(BUENO)
  fechaAdq       DateTime?       @db.Date
  ultimaRevision DateTime?       @db.Date
  notas          String?         @db.Text
  createdAt      DateTime        @default(now()) @db.Timestamptz
  updatedAt      DateTime        @updatedAt @db.Timestamptz

  habitacion Habitacion     @relation(fields: [habitacionId], references: [id])
  mueble     CatalogoMueble @relation(fields: [muebleId], references: [id])

  @@map("muebles_habitacion")
}

// ------------------------------------------------------------
// 9. PLANES TARIFARIOS
// ------------------------------------------------------------

model PlanTarifa {
  id               String              @id @default(uuid()) @db.Uuid
  codigo           String              @unique @db.VarChar(20)
  nombre           String              @db.VarChar(100)
  incluyeDesayuno  Boolean             @default(false)
  incluyeAlmuerzo  Boolean             @default(false)
  incluyeCena      Boolean             @default(false)
  politicaCancel   PoliticaCancelacion @default(FLEXIBLE)
  horasCancel      Int                 @default(24)
  nochesMinimas    Int                 @default(1)
  activo           Boolean             @default(true)
  descripcion      String?             @db.Text
  createdAt        DateTime            @default(now()) @db.Timestamptz
  updatedAt        DateTime            @updatedAt @db.Timestamptz

  tarifas  Tarifa[]
  reservas Reserva[]

  @@map("planes_tarifa")
}

// ------------------------------------------------------------
// 10. TEMPORADAS
// ------------------------------------------------------------

model Temporada {
  id            String        @id @default(uuid()) @db.Uuid
  nombre        String        @db.VarChar(80)
  tipo          TipoTemporada
  fechaInicio   DateTime      @db.Date
  fechaFin      DateTime      @db.Date
  multiplicador Decimal       @default(1.00) @db.Decimal(4, 2)
  notas         String?       @db.Text
  createdAt     DateTime      @default(now()) @db.Timestamptz
  updatedAt     DateTime      @updatedAt @db.Timestamptz

  tarifas Tarifa[]

  @@map("temporadas")
}

// ------------------------------------------------------------
// 11. TARIFAS
// ------------------------------------------------------------

model Tarifa {
  id               String    @id @default(uuid()) @db.Uuid
  tipoHabitacionId String    @db.Uuid
  planId           String    @db.Uuid
  temporadaId      String?   @db.Uuid
  canalId          String?   @db.Uuid
  precioNoche      Decimal   @db.Decimal(10, 2)
  precioAdultoExtra Decimal  @default(0) @db.Decimal(8, 2)
  precioNinoExtra  Decimal   @default(0) @db.Decimal(8, 2)
  moneda           String    @default("USD") @db.Char(3)
  vigenciaDesde    DateTime? @db.Date
  vigenciaHasta    DateTime? @db.Date
  createdAt        DateTime  @default(now()) @db.Timestamptz
  updatedAt        DateTime  @updatedAt @db.Timestamptz

  tipoHabitacion TipoHabitacion @relation(fields: [tipoHabitacionId], references: [id])
  plan           PlanTarifa     @relation(fields: [planId], references: [id])
  temporada      Temporada?     @relation(fields: [temporadaId], references: [id])
  canal          Canal?         @relation(fields: [canalId], references: [id])

  @@unique([tipoHabitacionId, planId, temporadaId, canalId])
  @@map("tarifas")
}

// ------------------------------------------------------------
// 12. PERSONAL
// ------------------------------------------------------------

model Personal {
  id            String      @id @default(uuid()) @db.Uuid
  userId        String?     @unique // FK a better-auth User
  codigo        String      @unique @db.VarChar(20)
  nombres       String      @db.VarChar(80)
  apellidos     String      @db.VarChar(80)
  rol           RolPersonal
  email         String?     @db.VarChar(100)
  telefono      String?     @db.VarChar(20)
  fechaIngreso  DateTime?   @db.Date
  activo        Boolean     @default(true)
  createdAt     DateTime    @default(now()) @db.Timestamptz
  updatedAt     DateTime    @updatedAt @db.Timestamptz

  user             User?         @relation(fields: [userId], references: [id])

  pagosRecibidos   Pago[]          @relation("PagosRecibidos")
  cargosRegistrados CargoFolio[]   @relation("CargosRegistrados")
  checkinsRealizados Estancia[]    @relation("CheckinPor")
  checkoutsRealizados Estancia[]   @relation("CheckoutPor")

  @@map("personal")
}

// ------------------------------------------------------------
// 13. SERVICIOS / CATÁLOGO COBRABLE
// ------------------------------------------------------------

model Servicio {
  id             String            @id @default(uuid()) @db.Uuid
  codigo         String            @unique @db.VarChar(30)
  nombre         String            @db.VarChar(150)
  categoria      CategoriaServicio
  precioUnitario Decimal           @db.Decimal(10, 2)
  moneda         String            @default("USD") @db.Char(3)
  igvPct         Decimal           @default(18.00) @db.Decimal(5, 2)
  activo         Boolean           @default(true)
  descripcion    String?           @db.Text
  createdAt      DateTime          @default(now()) @db.Timestamptz
  updatedAt      DateTime          @updatedAt @db.Timestamptz

  cargos CargoFolio[]

  @@map("servicios")
}

// ------------------------------------------------------------
// 14. RESERVAS
// ------------------------------------------------------------

model Reserva {
  id            String        @id @default(uuid()) @db.Uuid
  codigo        String        @unique @db.VarChar(20)
  huespedId     String        @db.Uuid
  agenciaId     String?       @db.Uuid
  canalId       String        @db.Uuid
  tipoHabId     String        @db.Uuid
  planId        String        @db.Uuid

  fechaEntrada  DateTime      @db.Date
  fechaSalida   DateTime      @db.Date
  noches        Int?          // calculado en BD, solo lectura

  adultos       Int           @default(1)
  ninos         Int           @default(0)

  precioNoche   Decimal       @db.Decimal(10, 2)
  montoTotal    Decimal       @db.Decimal(12, 2)
  moneda        String        @default("USD") @db.Char(3)

  estado        EstadoReserva @default(TENTATIVA)
  motivoCancel  String?       @db.Text
  canceladoEn   DateTime?     @db.Timestamptz
  refExterna    String?       @db.VarChar(100)
  nroVoucher    String?       @db.VarChar(50)
  solicitudes   String?       @db.Text
  horaLlegada   DateTime?     @db.Time
  createdAt     DateTime      @default(now()) @db.Timestamptz
  updatedAt     DateTime      @updatedAt @db.Timestamptz

  huesped       Huesped        @relation(fields: [huespedId], references: [id])
  agencia       Agencia?       @relation(fields: [agenciaId], references: [id])
  canal         Canal          @relation(fields: [canalId], references: [id])
  tipoHabitacion TipoHabitacion @relation(fields: [tipoHabId], references: [id])
  plan          PlanTarifa     @relation(fields: [planId], references: [id])

  pagos     Pago[]
  estancias Estancia[]

  @@map("reservas")
}

// ------------------------------------------------------------
// 15. PAGOS
// ------------------------------------------------------------

model Pago {
  id            String       @id @default(uuid()) @db.Uuid
  reservaId     String       @db.Uuid
  folioId       String?      @db.Uuid

  concepto      ConceptoPago
  estado        EstadoPago   @default(CONFIRMADO)

  fechaPago     DateTime     @default(now()) @db.Date
  monto         Decimal      @db.Decimal(12, 2)
  moneda        String       @default("USD") @db.Char(3)
  metodo        MetodoPago
  referencia    String?      @db.VarChar(100)
  recibidoPorId String?      @db.Uuid
  notas         String?      @db.Text
  pagoOrigenId  String?      @db.Uuid
  createdAt     DateTime     @default(now()) @db.Timestamptz

  reserva      Reserva   @relation(fields: [reservaId], references: [id])
  folio        Folio?    @relation(fields: [folioId], references: [id])
  recibidoPor  Personal? @relation("PagosRecibidos", fields: [recibidoPorId], references: [id])
  pagoOrigen   Pago?     @relation("PagoDevolucion", fields: [pagoOrigenId], references: [id])
  devoluciones Pago[]    @relation("PagoDevolucion")

  @@map("pagos")
}

// ------------------------------------------------------------
// 16. ESTANCIAS
// ------------------------------------------------------------

model Estancia {
  id           String        @id @default(uuid()) @db.Uuid
  reservaId    String        @db.Uuid
  habitacionId String        @db.Uuid
  huespedId    String        @db.Uuid

  horaEntrada  DateTime      @default(now()) @db.Timestamptz
  horaSalida   DateTime?     @db.Timestamptz

  estado       EstadoEstadia @default(EN_CASA)
  checkinPorId  String?      @db.Uuid
  checkoutPorId String?      @db.Uuid
  notas        String?       @db.Text
  createdAt    DateTime      @default(now()) @db.Timestamptz

  reserva    Reserva    @relation(fields: [reservaId], references: [id])
  habitacion Habitacion @relation(fields: [habitacionId], references: [id])
  huesped    Huesped    @relation(fields: [huespedId], references: [id])
  checkinPor  Personal? @relation("CheckinPor",  fields: [checkinPorId],  references: [id])
  checkoutPor Personal? @relation("CheckoutPor", fields: [checkoutPorId], references: [id])

  folio Folio?

  @@map("estancias")
}

// ------------------------------------------------------------
// 17. FOLIOS
// ------------------------------------------------------------

model Folio {
  id           String      @id @default(uuid()) @db.Uuid
  estanciaId   String      @unique @db.Uuid
  nroFolio     String      @unique @db.VarChar(20)
  estado       EstadoFolio @default(ABIERTO)
  moneda       String      @default("USD") @db.Char(3)
  totalCargos  Decimal     @default(0) @db.Decimal(12, 2)
  totalPagos   Decimal     @default(0) @db.Decimal(12, 2)
  // saldo = totalCargos - totalPagos (calculado en BD, solo lectura)
  saldo        Decimal?    @db.Decimal(12, 2)
  cerradoEn    DateTime?   @db.Timestamptz
  notas        String?     @db.Text
  createdAt    DateTime    @default(now()) @db.Timestamptz
  updatedAt    DateTime    @updatedAt @db.Timestamptz

  estancia    Estancia      @relation(fields: [estanciaId], references: [id])
  cargos      CargoFolio[]
  pagos       Pago[]
  comprobantes Comprobante[]

  @@map("folios")
}

// ------------------------------------------------------------
// 18. CARGOS AL FOLIO
// ------------------------------------------------------------

model CargoFolio {
  id            String   @id @default(uuid()) @db.Uuid
  folioId       String   @db.Uuid
  servicioId    String   @db.Uuid

  fechaCargo    DateTime @default(now()) @db.Date
  cantidad      Decimal  @default(1) @db.Decimal(8, 2)
  precioUnit    Decimal  @db.Decimal(10, 2)
  // subtotal, montoIgv, total: calculados en BD, solo lectura
  subtotal      Decimal? @db.Decimal(12, 2)
  igvPct        Decimal  @default(18.00) @db.Decimal(5, 2)
  montoIgv      Decimal? @db.Decimal(12, 2)
  total         Decimal? @db.Decimal(12, 2)
  descripcion   String?  @db.Text
  registradoPorId String? @db.Uuid
  anulado       Boolean  @default(false)
  motivoAnul    String?  @db.Text
  createdAt     DateTime @default(now()) @db.Timestamptz

  folio         Folio     @relation(fields: [folioId], references: [id])
  servicio      Servicio  @relation(fields: [servicioId], references: [id])
  registradoPor Personal? @relation("CargosRegistrados", fields: [registradoPorId], references: [id])

  @@map("cargos_folio")
}

// ------------------------------------------------------------
// 19. COMPROBANTES SUNAT
// ------------------------------------------------------------

model Comprobante {
  id               String          @id @default(uuid()) @db.Uuid
  folioId          String          @db.Uuid
  tipo             TipoComprobante
  serie            String          @db.VarChar(5)
  numero           Int
  fechaEmision     DateTime        @default(now()) @db.Date
  tipoDocReceptor  String?         @db.VarChar(10)
  nroDocReceptor   String?         @db.VarChar(11)
  nombreReceptor   String?         @db.VarChar(200)
  dirReceptor      String?         @db.Text
  subtotal         Decimal         @db.Decimal(12, 2)
  igv              Decimal         @db.Decimal(10, 2)
  total            Decimal         @db.Decimal(12, 2)
  estadoSunat      EstadoSunat     @default(PENDIENTE)
  codigoSunat      String?         @db.VarChar(50)
  createdAt        DateTime        @default(now()) @db.Timestamptz

  folio Folio @relation(fields: [folioId], references: [id])

  @@unique([serie, numero])
